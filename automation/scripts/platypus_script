#!/bin/bash
# Wrapper script for BankImport.app (Platypus Web View + Droppable).
#
# On launch: outputs the dashboard HTML to stdout — Platypus renders it.
# On drop:   receives dropped file paths as $@ — copies any CSVs into
#            the LOCAL inbox that the launchd watcher monitors, then
#            outputs the refreshed dashboard.
#
# Platypus calls this script each time the app is launched OR files are
# dropped on the icon/window. Whatever it prints to stdout becomes the
# web view's content.
#
# IMPORTANT: This script does NOT process CSVs itself. It drops them
# into the launchd-watched inbox so inbox_handler.sh handles everything
# (with proper FDA grants). This avoids TCC "Operation not permitted"
# errors that would hit if we tried to call run_append.sh from Platypus.

set -u

BANK_DIR="/Users/ronaldniddrie/Library/Mobile Documents/com~apple~CloudDocs/Documents/Claude/Projects/Bank Transactions"
LOCAL_INBOX="$HOME/Library/Application Support/BankImport/Inbox"
DASHBOARD="$BANK_DIR/bank_dashboard.html"
LOG="$BANK_DIR/automation/bankimport_platypus.log"

{
    echo "-----"
    date "+%Y-%m-%d %H:%M:%S"
    echo "args: $*"
} >> "$LOG"

# If files were dropped on the app, copy CSVs into the local inbox.
# The launchd watcher (com.ronaldniddrie.bankimport) fires within ~5s
# and inbox_handler.sh does the rest.
CSV_COUNT=0
for f in "$@"; do
    case "$f" in
        *.csv|*.CSV)
            cp "$f" "$LOCAL_INBOX/" 2>>"$LOG" && {
                echo "  copied to inbox: $(basename "$f")" >> "$LOG"
                CSV_COUNT=$((CSV_COUNT + 1))
            } || {
                echo "  FAILED to copy: $f" >> "$LOG"
            }
            ;;
        *)
            echo "  skipping non-CSV: $f" >> "$LOG"
            ;;
    esac
done

if [ "$CSV_COUNT" -gt 0 ]; then
    echo "  $CSV_COUNT CSV(s) queued — launchd watcher will process shortly" >> "$LOG"
fi

# Always emit the (possibly updated) dashboard.
if [ -f "$DASHBOARD" ]; then
    cat "$DASHBOARD"
else
    cat <<EOF
<!doctype html>
<html><head><meta charset="utf-8"><title>BankImport</title>
<style>body{font-family:-apple-system,sans-serif;background:#0f1420;color:#c6e0f2;padding:40px}</style>
</head><body>
<h1>Dashboard not found</h1>
<p>Expected <code>$DASHBOARD</code> — run <code>rebuild_dashboard.py</code> first.</p>
</body></html>
EOF
fi
