# Copy this file to .env and fill in the real values.
# The .env file itself should never be committed or synced.

# Your Enable Banking sandbox application ID (from the control panel)
ENABLE_BANKING_APP_ID=23fd7c0f-74c8-43d5-aae5-417fcfc28756

# Absolute path to the private key .pem file you saved when registering the app
# On the hotel laptop:
#   ENABLE_BANKING_KEY_PATH=/Users/ronaldniddrie/.config/enable-banking/sandbox_private_key.pem/Users/ronnie/projects/enable-banking/sandbox_private_key.pem
# On the Mac Mini (later):
#   ENABLE_BANKING_KEY_PATH=/Users/ronaldniddrie/.config/enable-banking/sandbox_private_key.pem/Users/ronnie/.config/enable-banking/sandbox_private_key.pem
ENABLE_BANKING_KEY_PATH=/Users/ronaldniddrie/.config/enable-banking/sandbox_private_key.pem

# Sandbox for now; we'll create a separate production application later
ENABLE_BANKING_ENV=sandbox

# UK — Halifax is part of Lloyds Banking Group
ENABLE_BANKING_COUNTRY=GB

# Name to match against /aspsps — try "Halifax" first. If not found the script
# will print the available names for country=GB so you can pick the right one.
# For the very first smoke test you can also use "Mock ASPSP" which is a
# guaranteed-working fake bank in Enable Banking's sandbox.
ENABLE_BANKING_ASPSP_NAME=Halifax

# Must exactly match the Allowed redirect URL you registered in the app
ENABLE_BANKING_REDIRECT=http://localhost:8765/callback
